<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PolymtkCp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PolymtkCp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">PolymtkCp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Traders/Index">Traders</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Traders/Leaderboard">Leaderboard</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item d-flex align-items-center me-2">
                            <span class="badge rounded-pill text-bg-light border font-monospace"
                                  data-bs-toggle="tooltip"
                                  title="Current UTC time — all timestamps in the app are UTC">
                                <span id="utc-clock">--:--:--</span> UTC
                            </span>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                @await Component.InvokeAsync("BalancePill")
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Profile">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</a>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout">
                                    <button type="submit" class="btn btn-link nav-link text-dark">Log out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Register">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Login">Log in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PolymtkCp - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Enable Bootstrap tooltips everywhere (used by the "?" help icons in table headers).
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
            // UTC clock in navbar
            var clock = document.getElementById('utc-clock');
            if (clock) {
                function tick() {
                    var d = new Date();
                    var hh = String(d.getUTCHours()).padStart(2, '0');
                    var mm = String(d.getUTCMinutes()).padStart(2, '0');
                    var ss = String(d.getUTCSeconds()).padStart(2, '0');
                    clock.textContent = hh + ':' + mm + ':' + ss;
                }
                tick();
                setInterval(tick, 1000);
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
