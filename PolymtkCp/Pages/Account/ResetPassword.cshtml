@page
@model PolymtkCp.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Set new password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">Set new password</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (Model.SuccessMessage is not null)
        {
            <div class="alert alert-success">
                @Model.SuccessMessage
                <a asp-page="/Account/Login" class="alert-link">Log in</a>
            </div>
        }

        @if (Model.SuccessMessage is null)
        {
            <form method="post">
                <input asp-for="AccessToken" type="hidden" />
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">New password</label>
                    <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100">Update password</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    {{-- Supabase puts the access_token in the URL hash (#). Extract it and set the hidden field. --}}
    <script>
        (function () {
            const hash = window.location.hash.substring(1);
            const params = new URLSearchParams(hash);
            const token = params.get('access_token');
            if (token) {
                document.querySelector('[name="AccessToken"]').value = token;
            }
        })();
    </script>
    <partial name="_ValidationScriptsPartial" />
}
