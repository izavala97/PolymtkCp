@page
@model PolymtkCp.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">Reset your password</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (Model.SuccessMessage is not null)
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100">Send reset link</button>
        </form>

        <p class="mt-3 text-center">
            <a asp-page="/Account/Login">Back to log in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
