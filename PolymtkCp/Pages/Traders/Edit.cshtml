@page "{id:guid}"
@model PolymtkCp.Pages.Traders.EditModel
@{
    ViewData["Title"] = "Edit copy plan";
}

<a asp-page="Detail" asp-route-id="@Model.PlanId" class="btn btn-link mb-3 ps-0">&larr; Back to trader</a>

<div class="row justify-content-center">
    <div class="col-md-7">
        <h2 class="mb-1">Edit copy plan</h2>
        @if (Model.TraderLabel is not null)
        {
            <p class="text-muted small mb-4">for @Model.TraderLabel</p>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <form method="post">
            <fieldset class="mb-4">
                <legend class="h5">Status</legend>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive" id="isActive" />
                    <label class="form-check-label" for="isActive">
                        <strong>Active</strong> &mdash; watcher emits copy-trades for this plan
                    </label>
                </div>
                <div class="form-text">Toggle off to pause copying without deleting the plan.</div>
            </fieldset>

            <fieldset class="mb-4">
                <legend class="h5">Mode</legend>
                <div class="mb-2">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Mode" value="paper" id="modePaper" />
                        <label class="form-check-label" for="modePaper">
                            <strong>Paper</strong> &mdash; simulated only.
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Mode" value="real" id="modeReal" disabled />
                        <label class="form-check-label text-muted" for="modeReal">
                            <strong>Real</strong> &mdash; orders submitted on your behalf.
                            <span class="badge bg-warning text-dark">Phase 2</span>
                        </label>
                    </div>
                </div>
            </fieldset>

            <fieldset class="mb-4">
                <legend class="h5">Sizing</legend>

                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="SizingMode" value="fixed" id="sizingFixed" />
                        <label class="form-check-label" for="sizingFixed">Fixed amount per trade</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="SizingMode" value="percent" id="sizingPercent" />
                        <label class="form-check-label" for="sizingPercent">Percentage of trader's notional</label>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3" data-sizing-field="fixed">
                        <label asp-for="FixedAmountUsd" class="form-label">Fixed amount (USDC)</label>
                        <input asp-for="FixedAmountUsd" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="FixedAmountUsd" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3" data-sizing-field="percent">
                        <label asp-for="PercentOfNotional" class="form-label">Percent of notional</label>
                        <input asp-for="PercentOfNotional" type="number" step="0.1" min="0" max="100" class="form-control" />
                        <span asp-validation-for="PercentOfNotional" class="text-danger small"></span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="mb-4">
                <legend class="h5">Daily limits (optional)</legend>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DailyTradeOperationsLimit" class="form-label"></label>
                        <input asp-for="DailyTradeOperationsLimit" type="number" min="1" class="form-control" />
                        <span asp-validation-for="DailyTradeOperationsLimit" class="text-danger small"></span>
                        <div class="form-text">Max number of copy-trades per day. Empty = no cap.</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DailyTradeMoneyLimit" class="form-label"></label>
                        <input asp-for="DailyTradeMoneyLimit" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="DailyTradeMoneyLimit" class="text-danger small"></span>
                        <div class="form-text">Max USDC spent on copy-trades per day. Empty = no cap.</div>
                    </div>
                </div>
            </fieldset>

            <fieldset class="mb-4">
                <legend class="h5">Grouping (optional)</legend>
                <div class="mb-3">
                    <label asp-for="GroupSimilarOps" class="form-label"></label>
                    <input asp-for="GroupSimilarOps" type="number" min="2" max="1000" class="form-control"
                           placeholder="e.g. 5 — leave empty to disable" />
                    <span asp-validation-for="GroupSimilarOps" class="text-danger small"></span>
                    <div class="form-text">
                        Collapse every N adjacent same-market same-side fills into 1 copy-trade.
                        The emitted copy's size is multiplied by the chunk size so volume is preserved.
                    </div>
                    <div class="alert alert-warning small mt-2 mb-0">
                        <strong>Heads up:</strong> with <code>fixed</code> sizing, if the trader accumulates in
                        many small fills and exits in one big order (or vice-versa), your copies will be
                        unbalanced. <code>percent</code> sizing mirrors the trader's proportions and avoids this.
                    </div>
                </div>
            </fieldset>

            <fieldset class="mb-4">
                <legend class="h5">Plan expiration (optional)</legend>
                <div class="mb-3">
                    <label asp-for="ExpiresAt" class="form-label"></label>
                    <input asp-for="ExpiresAt" class="form-control" />
                    <span asp-validation-for="ExpiresAt" class="text-danger small"></span>
                    <div class="form-text">Empty = no expiration.</div>
                </div>
            </fieldset>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-page="Detail" asp-route-id="@Model.PlanId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const radios = document.querySelectorAll('input[name="SizingMode"]');
            const fields = document.querySelectorAll('[data-sizing-field]');
            function sync() {
                const selected = document.querySelector('input[name="SizingMode"]:checked')?.value;
                fields.forEach(el => {
                    el.classList.toggle('d-none', el.dataset.sizingField !== selected);
                });
            }
            radios.forEach(r => r.addEventListener('change', sync));
            sync();
        })();
    </script>
}
