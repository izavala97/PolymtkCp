@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@if (!Model.IsAuthenticated)
{
    <section class="py-5 text-center">
        <h1 class="display-4 fw-semibold mb-3">Copy trades from top Polymarket traders</h1>
        <p class="lead text-muted mx-auto" style="max-width: 640px;">
            Pick a public wallet you believe in, set your sizing and daily limits, and let
            PolymtkCp mirror their moves on your own account. Paper-trade first, go live later.
        </p>

        <div class="d-flex gap-2 justify-content-center flex-wrap mt-4">
            <a class="btn btn-primary btn-lg" asp-page="/Account/Register">Create an account</a>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/Account/Login">Log in</a>
            <a class="btn btn-outline-dark btn-lg" href="@IndexModel.GitHubUrl" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                     class="bi bi-github me-1" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                             0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                             -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                             .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                             -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27
                             1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15
                             0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2
                             0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                View on GitHub
            </a>
        </div>
    </section>

    <section class="row g-4 mt-2 mb-5">
        <div class="col-md-4">
            <div class="p-4 h-100 border rounded-3 bg-light-subtle">
                <h5 class="mb-2">Read-only by default</h5>
                <p class="small text-muted mb-0">
                    Phase 1 ships as paper-trading only — the watcher records what <em>would</em>
                    have been copied. No orders are placed until you opt in.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 h-100 border rounded-3 bg-light-subtle">
                <h5 class="mb-2">You stay in control</h5>
                <p class="small text-muted mb-0">
                    Sizing (fixed $ or % of trader's trade), daily op + money limits, plan expiry,
                    and a kill-switch per Trader. Configure per wallet you copy.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 h-100 border rounded-3 bg-light-subtle">
                <h5 class="mb-2 d-flex align-items-center gap-2">
                    Open source
                    <span class="badge text-bg-secondary">MIT</span>
                </h5>
                <p class="small text-muted mb-0">
                    Every line of code is on
                    <a href="@IndexModel.GitHubUrl" target="_blank" rel="noopener">GitHub</a>.
                    Audit the watcher, RLS policies, and Data Protection setup before you trust it.
                </p>
            </div>
        </div>
    </section>
}
else
{
    <section class="py-4">
        <h1 class="h3 mb-4">Dashboard</h1>

        @if (string.IsNullOrWhiteSpace(Model.WalletAddress))
        {
            <div class="alert alert-info">
                <div class="fw-semibold mb-1">Connect your Polymarket wallet to get started.</div>
                <div class="small mb-2">
                    We use it (read-only) to show your portfolio value.
                </div>
                <a class="btn btn-primary btn-sm" asp-page="/Account/Profile">Go to profile</a>
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="p-3 border rounded-3 h-100">
                        <div class="text-muted small">Portfolio</div>
                        <div class="fs-4 fw-semibold">
                            @(Model.Portfolio is decimal p ? $"${p:N2}" : "—")
                            <span class="text-muted fw-normal fs-6">USDC</span>
                        </div>
                        @if (Model.BalanceFailed)
                        {
                            <div class="small text-danger">Could not load balance from Polymarket.</div>
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 border rounded-3 h-100">
                        <div class="text-muted small">Cash</div>
                        <div class="fs-4 fw-semibold">
                            @(Model.Cash is decimal c ? $"${c:N2}" : "—")
                            <span class="text-muted fw-normal fs-6">USDC.e on Polygon</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 border rounded-3 h-100">
                        <div class="text-muted small">Positions value</div>
                        <div class="fs-4 fw-semibold">
                            @(Model.Positions is decimal o ? $"${o:N2}" : "—")
                            <span class="text-muted fw-normal fs-6">market value</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="p-3 border rounded-3 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                        <h5 class="mb-0">Copy-trade volume (last 30d)</h5>
                        <div class="btn-group btn-group-sm" role="group" aria-label="Mode">
                            <input type="radio" class="btn-check" name="chartMode" id="chartModePaper" value="paper" checked>
                            <label class="btn btn-outline-primary" for="chartModePaper">
                                Paper · @Model.TotalPaperTrades · $@Model.TotalPaperUsdc.ToString("N2")
                            </label>
                            <input type="radio" class="btn-check" name="chartMode" id="chartModeReal" value="real"
                                   @(Model.HasRealTrades ? "" : "disabled")>
                            <label class="btn btn-outline-success" for="chartModeReal">
                                Real · @Model.TotalRealTrades · $@Model.TotalRealUsdc.ToString("N2")
                            </label>
                        </div>
                    </div>
                    <div style="position: relative; height: 220px;">
                        <canvas id="volumeChart"></canvas>
                    </div>
                    <div class="small text-muted mt-2">
                        Cumulative USDC deployed by your active copy-plans.
                        <strong>Paper</strong> = simulated (what <em>would</em> have been copied);
                        <strong>Real</strong> = orders placed on your Polymarket account (phase 2).
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="p-3 border rounded-3 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="mb-0">Recent movements</h5>
                        <a class="small" asp-page="/Traders/Index">All traders &rarr;</a>
                    </div>

                    @if (Model.RecentExecutions.Count == 0)
                    {
                        <div class="text-muted small py-3 text-center">
                            No copy-trades yet. Add a trader from
                            <a asp-page="/Traders/Index">Traders</a>
                            and the watcher will start mirroring their moves.
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush small">
                            @foreach (var ex in Model.RecentExecutions)
                            {
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold">
                                            @ex.Side $@ex.SizeUsdc.ToString("N2")
                                            @if (!string.IsNullOrEmpty(ex.Outcome))
                                            {
                                                <span class="text-muted fw-normal"> · @ex.Outcome</span>
                                            }
                                        </span>
                                        <span class="@(ex.Status == "simulated" ? "text-success" : "text-muted")">
                                            @ex.Status
                                        </span>
                                    </div>
                                    <div class="text-muted text-truncate" title="@ex.EventTitle">
                                        @(ex.EventTitle ?? "(market)")
                                    </div>
                                    <div class="text-muted" style="font-size: .75rem;">
                                        @ex.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                        @if (ex.Status == "skipped" && !string.IsNullOrEmpty(ex.Reason))
                                        {
                                            <span> · @ex.Reason</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"
                crossorigin="anonymous"></script>
        <script>
            (function () {
                const ctx = document.getElementById('volumeChart');
                if (!ctx) return;
                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
                const paperData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartPaperCumulativeUsdc));
                const realData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartRealCumulativeUsdc));

                const styles = {
                    paper: { label: 'Cumulative USDC (paper)', border: '#0d6efd', bg: 'rgba(13, 110, 253, .08)' },
                    real:  { label: 'Cumulative USDC (real)',  border: '#198754', bg: 'rgba(25, 135, 84, .08)' }
                };

                const chart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: styles.paper.label,
                            data: paperData,
                            borderColor: styles.paper.border,
                            backgroundColor: styles.paper.bg,
                            fill: true, tension: .25, pointRadius: 0, borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { callback: v => '$' + v }
                            }
                        }
                    }
                });

                document.querySelectorAll('input[name="chartMode"]').forEach(el => {
                    el.addEventListener('change', e => {
                        const mode = e.target.value;
                        const s = styles[mode];
                        const ds = chart.data.datasets[0];
                        ds.label = s.label;
                        ds.data = mode === 'real' ? realData : paperData;
                        ds.borderColor = s.border;
                        ds.backgroundColor = s.bg;
                        chart.update();
                    });
                });
            })();
        </script>
    }
}
